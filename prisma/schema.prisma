// Prisma schema — turbul-booking
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================================
// Authentification (better-auth) — tables gérées par better-auth
// =====================================================================

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions       Session[]
  accounts       Account[]
  bookingsCreated Booking[] @relation("BookingCreatedBy")
  unavailabilitiesCreated CaravanUnavailability[] @relation("UnavailabilityCreatedBy")
  issuesCreated   CaravanIssue[] @relation("IssueCreatedBy")
  issuesResolved  CaravanIssue[] @relation("IssueResolvedBy")
  auditLogs       AuditLog[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// =====================================================================
// Domaine métier — caravanes, lits, hôtes, réservations
// =====================================================================

model Caravan {
  id             String    @id @default(cuid())
  name           String
  lat            Float
  lng            Float
  rotation       Float     @default(0)   // orientation en degrés (0–360)
  width          Float     @default(2.5) // largeur en mètres
  length         Float     @default(6.0) // longueur en mètres
  hasElectricity Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  beds             Bed[]
  unavailabilities CaravanUnavailability[]
  issues           CaravanIssue[]

  @@index([deletedAt])
}

// Journal de problèmes / état d'une caravane (to-do list par caravane).
// Un manager peut ajouter un item, le marquer comme résolu (résolu = on
// renseigne resolvedAt + resolvedById), réouvrir (mettre à null), ou
// supprimer définitivement.
model CaravanIssue {
  id           String    @id @default(cuid())
  caravanId    String
  label        String
  createdAt    DateTime  @default(now())
  createdById  String
  resolvedAt   DateTime?
  resolvedById String?

  caravan    Caravan @relation(fields: [caravanId], references: [id], onDelete: Cascade)
  createdBy  User    @relation("IssueCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  resolvedBy User?   @relation("IssueResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([caravanId, resolvedAt])
}

// Période durant laquelle la caravane est indisponible (toutes ses lits sont
// bloqués). `to` est exclusif : 1 nuit bloquée = `to = from + 1 jour`.
model CaravanUnavailability {
  id          String   @id @default(cuid())
  caravanId   String
  from        DateTime @db.Date
  to          DateTime @db.Date
  reason      String?
  createdById String
  createdAt   DateTime @default(now())

  caravan   Caravan @relation(fields: [caravanId], references: [id], onDelete: Cascade)
  createdBy User    @relation("UnavailabilityCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([caravanId, from, to])
  @@index([from, to])
}

model Bed {
  id            String  @id @default(cuid())
  caravanId     String
  label         String
  capacity      Int     // 1, 2 ou 3
  position      Int     @default(0) // ordre d'affichage dans la caravane
  hasCleanLinen Boolean @default(false)

  caravan  Caravan   @relation(fields: [caravanId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([caravanId])
}

model Guest {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([lastName, firstName])
}

// Une ligne par nuit. La capacité du lit est vérifiée applicativement
// (count(bookings où bedId=X et date=Y) ≤ bed.capacity).
model Booking {
  id          String   @id @default(cuid())
  bedId       String
  guestId     String
  date        DateTime @db.Date
  createdById String
  createdAt   DateTime @default(now())

  bed       Bed   @relation(fields: [bedId], references: [id], onDelete: Restrict)
  guest     Guest @relation(fields: [guestId], references: [id], onDelete: Restrict)
  createdBy User  @relation("BookingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([bedId, date, guestId])
  @@index([bedId, date])
  @@index([date])
  @@index([guestId])
}

// Zones décoratives sur le plan (polygones libres). Pas de lien aux
// réservations : sert uniquement de repère visuel.
model Zone {
  id        String   @id @default(cuid())
  name      String
  color     String
  filled    Boolean  @default(true)
  points    Json     // [[lat, lng], [lat, lng], ...] — au moins 3 sommets
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Murs décoratifs sur le plan (polylignes libres). Purement visuel.
model Wall {
  id        String   @id @default(cuid())
  color     String
  thickness Float    @default(3)
  points    Json     // [[lat, lng], [lat, lng], ...] — au moins 2 sommets
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // ex: CARAVAN_CREATE, CARAVAN_MOVE, BED_UPDATE, BOOKING_CREATE...
  entityType String   // ex: Caravan, Bed, Booking, Guest, User
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
}
